# --- Database -------------------------------------------------------------
# Local docker-compose Postgres (see docker-compose.yml). Host port is 5433.
DATABASE_URL="postgresql://catergenie:catergenie@localhost:5433/catergenie?schema=public"

# --- AI Insights (Anthropic) ---------------------------------------------
# Optional. Without it, the dashboard still works; AI Insights degrades to a
# deterministic rules-based summary instead of an LLM narrative.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# --- Authentication (Clerk) ----------------------------------------------
# Optional. With both keys set, the app requires sign-in (middleware protects
# all routes); without them auth is OFF and the app is open. Create an app at
# https://dashboard.clerk.com and copy its keys. The publishable key must be
# present at BUILD time (it is inlined into the client bundle).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# Sign-up is intentionally disabled (no public /sign-up route). Manage users +
# restrict sign-ups in the Clerk dashboard (Restrictions → invitation/allowlist).
# Dedicated test user for automated/agent testing — sign in with these to reach
# protected routes. Never commit real values.
CLERK_TEST_USER_EMAIL=""
CLERK_TEST_USER_PASSWORD=""

# --- Source system connectors (future live ingestion) --------------------
# All optional today — the seeder loads historical data from the spreadsheets.
# Fill these in once credentials/access are granted to enable live jobs.

# Clover POS (retail) — merchant token path
CLOVER_BASE_URL="https://api.clover.com"
CLOVER_MERCHANT_ID=""
CLOVER_API_TOKEN=""

# When I Work (labor)
WHENIWORK_BASE_URL="https://api.wheniwork.com/2"
WHENIWORK_API_TOKEN=""

# QuickBooks Online (accounting) — OAuth 2.0
# Create an app at https://developer.intuit.com → copy its Client ID/Secret.
# With these set, click "Connect QuickBooks" in the app (Sources panel) to
# authorize a company; tokens are stored + auto-refreshed in the DB.
QBO_CLIENT_ID=""
QBO_CLIENT_SECRET=""
# Must exactly match a Redirect URI registered on the Intuit app.
QBO_REDIRECT_URI="http://localhost:3000/api/qbo/callback"
QBO_ENV="production" # or "sandbox"
QBO_BASE_URL="https://quickbooks.api.intuit.com"
# Manual fallback (e.g. tokens from Intuit's OAuth Playground):
QBO_REALM_ID=""
QBO_ACCESS_TOKEN=""
QBO_REFRESH_TOKEN=""

# CaterTrax (delivery) — no public API; scheduled report drop (SFTP/email).
# Path the report-ingest job watches for dropped CSV/XLSX exports.
CATERTRAX_DROP_DIR="./drop/catertrax"
