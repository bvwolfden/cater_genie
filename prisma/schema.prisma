// CaterGenie — operational data model.
//
// Architecture: ingestion jobs (Clover / CaterTrax / When I Work / QuickBooks)
// write into the normalized tables below; a rollup builds `DailyMetric`, which
// the dashboard reads. Today the spreadsheet seeder populates these directly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum SourceSystem {
  CLOVER // retail POS
  CATERTRAX // corporate delivery
  WHENIWORK // labor / time
  QUICKBOOKS // accounting
  CATEREASE // events (investigated separately)
  SPREADSHEET // historical seed
  MANUAL
}

enum SalesChannel {
  CAFE_RETAIL // Clover / cafe net sales
  CATERTRAX // corporate delivery
  CATEREASE // events
  ALOHA // legacy POS line seen in projections
  OTHER
}

enum AccountType {
  OPERATING
  PAYROLL
  MERCHANT
  SAVINGS
  HOLDING
  CC_PROCESSING
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

// ---------------------------------------------------------------------------
// Daily read model (the "Daily Tracker")
// ---------------------------------------------------------------------------

/// One canonical row per business day — what the dashboard reads first.
model DailyMetric {
  id            Int       @id @default(autoincrement())
  date          DateTime  @unique @db.Date
  weekLabel     String?
  netSales      Decimal?  @db.Decimal(14, 2)
  tax           Decimal?  @db.Decimal(14, 2)
  laborCost     Decimal?  @db.Decimal(14, 2)
  laborHours    Decimal?  @db.Decimal(10, 2)
  laborPct      Decimal?  @db.Decimal(8, 5) // fraction: 0.27 = 27%
  foodPurchases Decimal?  @db.Decimal(14, 2)
  notes         String?
  source        SourceSystem @default(SPREADSHEET)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([date])
}

/// Channel-grain daily sales — the target shape for live connectors
/// (Clover retail, CaterTrax delivery). Empty until connectors run.
model DailySales {
  id         Int          @id @default(autoincrement())
  date       DateTime     @db.Date
  channel    SalesChannel
  netSales   Decimal?     @db.Decimal(14, 2)
  tax        Decimal?     @db.Decimal(14, 2)
  grossSales Decimal?     @db.Decimal(14, 2)
  orderCount Int?
  source     SourceSystem @default(SPREADSHEET)
  createdAt  DateTime     @default(now())

  @@unique([date, channel])
  @@index([date])
}

/// Per employee-day labor punch (When I Work / timesheet export).
model LaborEntry {
  id           Int          @id @default(autoincrement())
  date         DateTime     @db.Date
  employeeId   String?
  firstName    String?
  lastName     String?
  department   String? // "schedule": Cater Hot, Cafe, Delivery, SALES...
  position     String?
  jobSite      String?
  regularHours Decimal?     @db.Decimal(10, 2)
  otHours      Decimal?     @db.Decimal(10, 2)
  doubleOtHours Decimal?    @db.Decimal(10, 2)
  hourlyRate   Decimal?     @db.Decimal(10, 2)
  paidTotal    Decimal?     @db.Decimal(14, 2)
  tips         Decimal?     @db.Decimal(14, 2)
  earningsTotal Decimal?    @db.Decimal(14, 2)
  source       SourceSystem @default(SPREADSHEET)
  createdAt    DateTime     @default(now())

  @@index([date])
  @@index([department])
}

/// QuickBooks account balance snapshot (date, account).
model AccountBalance {
  id        Int          @id @default(autoincrement())
  date      DateTime     @db.Date
  account   AccountType
  balance   Decimal      @db.Decimal(14, 2)
  source    SourceSystem @default(SPREADSHEET)
  createdAt DateTime     @default(now())

  @@unique([date, account])
  @@index([date])
}

// ---------------------------------------------------------------------------
// Weekly comparisons & projections
// ---------------------------------------------------------------------------

/// Weekly revenue by channel — actual vs projected (Sales Comp + projections).
model WeeklyChannelRevenue {
  id        Int          @id @default(autoincrement())
  weekStart DateTime     @db.Date
  weekEnd   DateTime?    @db.Date
  channel   SalesChannel
  actual    Decimal?     @db.Decimal(14, 2)
  projected Decimal?     @db.Decimal(14, 2)
  createdAt DateTime     @default(now())

  @@unique([weekStart, channel])
  @@index([weekStart])
}

/// Weekly company rollup — totals, YoY history, and labor (Weekly Sales Comp).
model WeeklyRollup {
  id             Int       @id @default(autoincrement())
  weekStart      DateTime  @unique @db.Date
  weekEnd        DateTime? @db.Date
  totalRevenue   Decimal?  @db.Decimal(14, 2)
  revenuePrev1   Decimal?  @db.Decimal(14, 2) // prior year
  revenuePrev2   Decimal?  @db.Decimal(14, 2)
  revenuePrev3   Decimal?  @db.Decimal(14, 2)
  projectedTotal Decimal?  @db.Decimal(14, 2)
  laborCost      Decimal?  @db.Decimal(14, 2)
  laborPrev1     Decimal?  @db.Decimal(14, 2) // prior-year (2025) weekly labor
  laborPrev2     Decimal?  @db.Decimal(14, 2) // 2024 weekly labor
  laborPct       Decimal?  @db.Decimal(8, 5)
  hoursPaid      Decimal?  @db.Decimal(10, 2)
  createdAt      DateTime  @default(now())

  @@index([weekStart])
}

// ---------------------------------------------------------------------------
// Ops / provenance
// ---------------------------------------------------------------------------

/// One row per ingestion job execution — powers data-freshness on the dashboard.
model SyncRun {
  id          Int          @id @default(autoincrement())
  source      SourceSystem
  status      SyncStatus   @default(PENDING)
  rowsWritten Int          @default(0)
  startedAt   DateTime     @default(now())
  finishedAt  DateTime?
  message     String?

  @@index([source, startedAt])
}

/// OAuth tokens for connected integrations (e.g., QuickBooks Online).
model IntegrationToken {
  id           Int       @id @default(autoincrement())
  provider     String    @unique // "QBO"
  accessToken  String?
  refreshToken String?
  realmId      String?
  expiresAt    DateTime?
  meta         Json?
  updatedAt    DateTime  @updatedAt
}

/// Cached AI insight for a given date/scope, so we don't re-bill on every load.
model Insight {
  id        Int      @id @default(autoincrement())
  scopeDate DateTime @db.Date
  scope     String   @default("daily") // daily | weekly
  headline  String?
  body      String? // markdown narrative
  payload   Json? // structured highlights/alerts
  model     String?
  createdAt DateTime @default(now())

  @@unique([scopeDate, scope])
}

/// A file dropped/uploaded for AI-parsed ingestion (the "drop zone").
/// Parsed rows wait here for human review before committing to the real tables —
/// numbers never pass through human fingers, but a human still approves them.
model ImportBatch {
  id          Int       @id @default(autoincrement())
  filename    String
  kind        String? // detected: daily_metrics | timesheet | catertrax_sales | caterease_bookings | unknown
  status      String    @default("PENDING") // PENDING | COMMITTED | REJECTED | FAILED
  archived    Boolean   @default(false) // rejected/dismissed cards move to the Archive tab
  summary     String? // parser's one-line description of what it found
  parsed      Json? // structured rows awaiting review
  error       String?
  rowsWritten Int       @default(0)
  createdAt   DateTime  @default(now())
  committedAt DateTime?
}

/// A future scheduled shift (When I Work schedule export today; WIW API once
/// creds land). Powers the staffing outlook: scheduled labor vs projected
/// demand, so over/under-staffing is flagged while there's still time to act.
model ScheduledShift {
  id          Int          @id @default(autoincrement())
  date        DateTime     @db.Date
  department  String? // WIW "Schedule": Cater Hot, Cafe, Delivery, SALES...
  position    String?
  employeeId  String?
  firstName   String?
  lastName    String?
  startTime   String? // "5:00 am" — display only
  endTime     String?
  unpaidBreak Decimal?     @db.Decimal(6, 2)
  hours       Decimal?     @db.Decimal(10, 2) // scheduled (paid) hours
  hourlyRate  Decimal?     @db.Decimal(10, 2)
  laborCost   Decimal?     @db.Decimal(14, 2) // hours × rate when not in the export
  status      String? // Published | Open | ...
  source      SourceSystem @default(WHENIWORK)
  createdAt   DateTime     @default(now())

  @@index([date])
  @@index([department])
}

/// One When I Work audit-log event (the "Shift History" export): every shift
/// create / edit / delete with previous values. Two things fall out of it:
/// the FINAL schedule for past dates (sum of deltas) and the BUILD CURVE —
/// how many hours are usually on the books N days before a given weekday.
/// Kevin builds most of each week's schedule in the final days, so raw
/// "scheduled vs typical worked" comparisons over-flag; this fixes that.
model ShiftEvent {
  id             Int          @id @default(autoincrement())
  occurredAt     DateTime // when the change happened
  reason         String // create | created-from-repeating-series | edit | delete | repeating-delete | publish | confirm | ...
  updatedFields  String?
  department     String? // Schedule Name
  prevDepartment String?
  assignee       String?
  employeeId     String?
  shiftDate      DateTime?    @db.Date // Start Date of the shift being changed
  prevShiftDate  DateTime?    @db.Date
  length         Decimal?     @db.Decimal(10, 2) // shift hours after the change
  prevLength     Decimal?     @db.Decimal(10, 2)
  position       String?
  source         SourceSystem @default(WHENIWORK)
  createdAt      DateTime     @default(now())

  @@index([shiftDate])
  @@index([occurredAt])
}

/// Forward event bookings (Caterease exports / manual). The missing input the
/// June forecast backtest identified: event days run ~7x a normal day.
model EventBooking {
  id        Int          @id @default(autoincrement())
  eventDate DateTime     @db.Date
  name      String?
  status    String? // definite | tentative | prospect...
  guests    Int?
  revenue   Decimal?     @db.Decimal(14, 2)
  eventTime String? // delivery/serve start time as shown by the source ("11:30 AM")
  company   String? // customer/company — proxy for the delivery building when grouping drops
  orderId   String? // CaterTrax order id — durable join key to DeliveryStop
  source    SourceSystem @default(MANUAL)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([eventDate, name])
  @@index([eventDate])
}

/// One CaterTrax delivery drop, keyed by the durable order id. Split from
/// EventBooking because the two data families have different owners:
/// enrichment (address/times, from the coversheet scrape) is overwritten by
/// the daily sync; assignment (driver) is Kevin's system of record and must
/// SURVIVE sync re-upserts. Sync only clears assignment if the order moves days.
model DeliveryStop {
  id           Int      @id @default(autoincrement())
  orderId      String   @unique
  date         DateTime @db.Date
  // enrichment — sync-owned, refreshed each run (coversheet.asp)
  deliveryTime String? // "11:00 AM"
  addressRaw   String? // "501 Grant Street Suite 200"
  city         String?
  zip          String?
  building     String? // "Union Trust Building" — same-building grouping key
  addressKey   String? // normalized street+zip → GeoPoint.addressKey
  // assignment — human-owned, never touched by sync
  driverKey    String? // ScheduledShift employeeId, else "first last" lowercased
  assignedAt   DateTime?
  assignedBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
}

/// Geocode cache — one row per normalized building address, geocoded once.
model GeoPoint {
  id         Int      @id @default(autoincrement())
  addressKey String   @unique
  addressRaw String
  lat        Float?
  lng        Float?
  provider   String? // "nominatim" | "census"
  failed     Boolean  @default(false) // don't re-hit the API for known misses
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// A falsifiable prediction the AI made on a given morning, later scored
/// against the real number that lands. This closes the COMPILOT-style loop:
/// the prediction is the "action", the next day's actual is the "measurement",
/// and `errorPct` is the feedback fed back into future prompts.
model Forecast {
  id          Int      @id @default(autoincrement())
  madeOnDate  DateTime @db.Date // the reporting day it was generated from (as-of)
  targetDate  DateTime @db.Date // the day (or week-start) being predicted
  horizon     String   @default("next_day") // next_day | next_week
  mode        String   @default("live") // live | backtest
  model       String?
  context     Json? // snapshot of what the model saw — audit trail / no leakage
  rationale   String? // why the model expects this

  predNetSales     Decimal? @db.Decimal(14, 2)
  predLaborPct     Decimal? @db.Decimal(8, 5)
  baselineNetSales Decimal? @db.Decimal(14, 2) // deterministic projection, for comparison

  // Ground truth, filled in when the actual day closes.
  actualNetSales Decimal?  @db.Decimal(14, 2)
  actualLaborPct Decimal?  @db.Decimal(8, 5)
  errorPct       Decimal?  @db.Decimal(10, 5) // signed (pred-actual)/actual on net sales
  absErrorPct    Decimal?  @db.Decimal(10, 5)
  baselineErrorPct Decimal? @db.Decimal(10, 5) // signed error of the deterministic baseline
  scoredAt       DateTime?

  createdAt DateTime @default(now())

  @@unique([madeOnDate, horizon, mode])
  @@index([targetDate, horizon, mode])
}
