{
  "name": "cater-genie",
  "version": "0.1.0",
  "private": true,
  "description": "Restaurant/catering daily operations dashboard — ingests Clover, CaterTrax, When I Work, and QuickBooks into Postgres and surfaces a daily dashboard with AI insights.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "db:start": "node scripts/local-db.mjs start",
    "db:stop": "node scripts/local-db.mjs stop",
    "db:embedded": "node scripts/pg-embedded.mjs",
    "db:push": "prisma db push --skip-generate && prisma generate",
    "extract": "python3 scripts/extract_spreadsheets.py",
    "seed": "tsx scripts/seed.ts",
    "ingest": "tsx scripts/ingest.ts",
    "setup": "npm run db:start && npm run db:push && npm run extract && npm run seed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@prisma/client": "^6.19.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.22.0",
    "next": "^15.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "dotenv": "^17.4.2",
    "embedded-postgres": "^18.4.0-beta.17",
    "postcss": "^8.5.16",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
